# Banco de dados PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cozinhai

# Segredos de autenticação (troque em produção)
BETTER_AUTH_SECRET=gere-um-segredo-aleatorio-aqui
JWT_SECRET=gere-outro-segredo-aqui

# URL pública do servidor (para autenticação)
BETTER_AUTH_URL=http://localhost:3100

# Porta do servidor (padrão: 3100)
PORT=3100

# Origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:5173
