# =============================================================
# CozinhAI — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================================

# Banco de dados PostgreSQL
DATABASE_URL=postgres://cozinhai:SENHA@localhost:5432/cozinhai

# Servidor
PORT=3100
NODE_ENV=production
TZ=America/Sao_Paulo

# Better Auth — gerar com: openssl rand -base64 32
BETTER_AUTH_SECRET=GERAR_AUTOMATICAMENTE
BETTER_AUTH_URL=http://SEU_DOMINIO_OU_IP:3100

# CORS — em produção: mesmo domínio do servidor
CORS_ORIGINS=http://SEU_DOMINIO_OU_IP:3100

# =============================================================
# LLM — preencher pelo menos um provedor
# =============================================================
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# =============================================================
# Comunicação (opcional — funcionalidades futuras)
# =============================================================
TELEGRAM_BOT_TOKEN=
WHATSAPP_TOKEN=
